# Copy to .env and fill in your values.
# Source with:  set -a; source .env; set +a

# ── Databricks workspace ────────────────────────────────────────────────
# Host portion only — no scheme, no trailing slash.
#   Example: dbc-a1b2c3d4-e5f6.cloud.databricks.com
WORKSPACE_URL="dbc-xxxxxxxx-xxxx.cloud.databricks.com"

# Numeric workspace ID. Find at Admin Settings → Workspace → Workspace ID,
# or in the URL as ?o=<digits> when browsing the workspace.
WORKSPACE_ID="0000000000000000"

# Cloud region of the workspace (drives the Zerobus endpoint hostname).
#   AWS examples: us-east-1, us-west-2
#   Azure examples: eastus2, westeurope
#   GCP examples: us-central1, europe-west4
REGION="us-west-2"

# ── Service principal OAuth credentials ─────────────────────────────────
# From: Settings → Identity and access → Service principals → <your SP> →
# Secrets → Generate secret. Client ID == Application ID (UUID).
DATABRICKS_CLIENT_ID="00000000-0000-0000-0000-000000000000"
DATABRICKS_CLIENT_SECRET="dose..."

# ── Unity Catalog destination ───────────────────────────────────────────
# Must match what you created in sql/01_create_tables.sql exactly.
# The final table name is: ${CATALOG}.${SCHEMA}.${TABLE_PREFIX}_otel_metrics
CATALOG="main"
SCHEMA="dgx_telemetry"
TABLE_PREFIX="nvidia"
